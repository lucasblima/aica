    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.84.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.13",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.554.0",
