# =============================================================================
# AICA Agents Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# These are used by the ADK multi-agent backend (main_agents.py).
# =============================================================================

# Google Gemini API Key (required)
# ADK uses GOOGLE_API_KEY by default, but we also support GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key

# Supabase configuration (required)
SUPABASE_URL=https://uzywajqzbdbrfammshdg.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Supabase JWT secret for token verification (required)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Server port (optional, defaults to 8081)
PORT=8081
