# Test Environment Variables
# Copie para .env.test e preencha com seus valores de teste

# =====================================================
# SUPABASE (Local ou Remoto)
# =====================================================

# URL do projeto Supabase
# Local: http://localhost:54321
# Remoto: https://seu-projeto.supabase.co
VITE_SUPABASE_URL=http://localhost:54321

# Anon Key (público)
# Obtenha no Supabase Dashboard > Settings > API
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# =====================================================
# PYTHON LLM SERVER
# =====================================================

# URL do servidor Python
# Local: http://localhost:8001
# Produção: https://aica-llm-server.seu-dominio.com
VITE_LLM_API_URL=http://localhost:8001

# =====================================================
# TEST USER (Criar antes de rodar testes)
# =====================================================

# Email do usuário de teste
# Criar com: npx supabase auth create-user --email test@example.com
TEST_USER_EMAIL=test@example.com

# Senha do usuário de teste (mínimo 6 caracteres)
TEST_USER_PASSWORD=testpassword123

# =====================================================
# OPCIONAL - CONFIGURAÇÕES AVANÇADAS
# =====================================================

# Timeout para testes (ms)
# TEST_TIMEOUT=30000

# Verbose logging nos testes
# TEST_VERBOSE=true

# Skip testes que requerem backend rodando
# SKIP_BACKEND_TESTS=false
