# Supabase Edge Functions - Environment Variables
# Copie para .env e preencha com seus valores

# =====================================================
# GEMINI API
# =====================================================

# API Key do Google Gemini
# Obtenha em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# SUPABASE (Auto-preenchido em produção)
# =====================================================

# URL do projeto Supabase
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (admin access)
# ATENÇÃO: Nunca exponha esta chave no frontend!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# RATE LIMITING (Opcional - Override padrões)
# =====================================================

# Limite de requests por hora (padrão: 100)
# RATE_LIMIT_HOURLY=100

# Limite de requests por dia (padrão: 1000)
# RATE_LIMIT_DAILY=1000

# =====================================================
# CACHE (Opcional - Override TTLs)
# =====================================================

# TTL padrão do cache em segundos (padrão: 0 = sem cache)
# CACHE_DEFAULT_TTL=0

# TTL específicos por ação (em segundos)
# CACHE_TTL_SUGGEST_GUEST=86400  # 24 horas
# CACHE_TTL_GENERATE_DOSSIER=604800  # 7 dias
