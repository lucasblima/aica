# AICA Life OS - Environment Variables Template
# Copy this file to .env.local and populate with your actual values
# NEVER commit actual secrets to the repository

# =========================================================================
# GEMINI API
# =========================================================================
# Security: API keys are stored in Supabase Edge Functions (backend only)
# Do NOT add GEMINI_API_KEY here - it should only be in Supabase secrets
# See docs/GEMINI_API_SETUP.md for setup instructions

# =========================================================================
# n8n Configuration
# =========================================================================
# n8n workflow automation platform for WhatsApp and other integrations
VITE_N8N_URL=https://n8n-n8n.your-domain.com/
VITE_N8N_API_KEY=your_n8n_api_key_jwt_token_here

# =========================================================================
# Supabase Configuration - FRONTEND ONLY
# =========================================================================
# PostgreSQL database and authentication backend
# URL: Public endpoint - safe to expose
# ANON_KEY: Public anonymous key - safe to expose
#
# ⚠️ SECURITY CRITICAL:
# DO NOT add SERVICE_KEY, JWT_SECRET, SERVICE_ROLE_KEY, or ACCESS_TOKEN to .env
# These privileged credentials are NEVER exposed in frontend code
# They are configured exclusively in Supabase Edge Functions secrets
# See docs/SECURITY_SETUP.md for proper Edge Function configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here

# Frontend URL for OAuth redirect
VITE_FRONTEND_URL=https://aica-your-project.southamerica-east1.run.app

# =========================================================================
# WhatsApp API Configuration (Evolution API) - BACKEND ONLY
# =========================================================================
# ⚠️ SECURITY CRITICAL:
# Evolution API credentials are NEVER exposed in frontend
# They are configured exclusively in Supabase Edge Functions secrets
# Frontend only needs to call Edge Function endpoints
# See docs/WHATSAPP_INTEGRATION_SETUP.md for proper configuration

# =========================================================================
# Metabase Configuration
# =========================================================================
# Business intelligence and analytics dashboard
VITE_METABASE_API_URL=https://metabase.your-domain.com/

# =========================================================================
# Custom App Configuration
# =========================================================================
# Internal custom applications
VITE_CUSTOM_APP_URL=https://custom-app-your-project.a.run.app

# =========================================================================
# Google Configuration
# =========================================================================
# Google Search API for content discovery
VITE_GOOGLE_SEARCH_KEY=your_google_search_api_key_here
VITE_GOOGLE_SEARCH_CX=your_google_custom_search_engine_id_here

# Google OAuth for authentication
VITE_GOOGLE_OAUTH_CLIENT_ID=your-project-number.apps.googleusercontent.com

# =========================================================================
# E2E Test Configuration
# =========================================================================
# Optional: Use for automated authentication in Playwright E2E tests
# If not set, tests will attempt to use Google OAuth flow
# WARNING: Never use real user credentials - create a dedicated test account
TEST_EMAIL=test.user@example.com
TEST_PASSWORD=your_test_account_password_here

# =========================================================================
# API Configuration
# =========================================================================
# Backend API endpoint
VITE_API_URL=http://localhost:3000

# =========================================================================
# Webhook Configuration
# =========================================================================
# n8n webhook for WhatsApp message processing
VITE_N8N_WEBHOOK_URL=https://n8n-n8n.your-domain.com/webhook/aica

# =========================================================================
# Microservice Configuration
# =========================================================================
# PDF extraction microservice for document processing
VITE_PDF_EXTRACTOR_URL=https://pdf-extractor.your-domain.com
