# =============================================================================
# AICA Environment Variables Template
# =============================================================================
#
# SECURITY WARNING - READ BEFORE CONFIGURING
# -------------------------------------------
# This is a TEMPLATE file with PLACEHOLDER values only.
# NEVER commit real credentials to this file.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace placeholder values with your actual credentials
# 3. The .env file is in .gitignore and should NEVER be committed
#
# =============================================================================

# =============================================================================
# REQUIRED: Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# =============================================================================

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key - safe to use in frontend
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# REQUIRED FOR PRODUCTION: Frontend URL
# This is used for OAuth redirect URLs
# =============================================================================

# Development
VITE_FRONTEND_URL=http://localhost:3000

# Production example (uncomment and modify):
# VITE_FRONTEND_URL=https://your-app.run.app

# =============================================================================
# OPTIONAL: AI Features (Gemini)
# Get this from: https://aistudio.google.com/apikey
# =============================================================================

# IMPORTANT: This key will be exposed in frontend JavaScript.
# Use restricted API keys with domain/IP restrictions for production.
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# OPTIONAL: Google OAuth (Direct OAuth, not through Supabase)
# Get these from: https://console.cloud.google.com/apis/credentials
# =============================================================================

VITE_GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# OPTIONAL: External Services
# =============================================================================

# n8n Webhook (for WhatsApp message processing)
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# PDF Extractor Microservice
# Development: http://localhost:8000
# Production: Your production URL
VITE_PDF_EXTRACTOR_URL=http://localhost:8000

# Evolution API Instance Name (for WhatsApp integration)
VITE_EVOLUTION_INSTANCE_NAME=your-instance-name

# General API URL
VITE_API_URL=http://localhost:3000

# =============================================================================
# TESTING: E2E Test Configuration
# =============================================================================

# If you don't set these, tests will attempt to use Google OAuth
# To get these values:
# 1. Create a test user account in your Supabase project
# 2. Set the email and password below
TEST_EMAIL=test-user@example.com
TEST_PASSWORD=your-test-password-here

# =============================================================================
# SECURITY REMINDER
# =============================================================================
# The following keys should NEVER be in frontend code:
# - SUPABASE_SERVICE_KEY / SUPABASE_SERVICE_ROLE_KEY
# - SUPABASE_JWT_SECRET
# - Any database passwords
# - Any server-side API keys
#
# These should only be used in backend services or Edge Functions.
# =============================================================================
