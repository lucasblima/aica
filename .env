# GEMINI API
# ⚠️ SECURITY: API keys have been moved to Supabase Edge Functions (backend)
# Do NOT add GEMINI_API_KEY here - it should only be in Supabase secrets
# See docs/GEMINI_API_SETUP.md for setup instructions

# n8n Configuration
VITE_N8N_URL=your_n8n_url_here
VITE_N8N_API_KEY=your_n8n_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_key_here
VITE_SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
VITE_SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

VITE_FRONTEND_URL=https://your-frontend-url-here.run.app

# WhatsApp API Configuration (Evolution API)
VITE_EVOLUTION_URL=your_evolution_url_here
VITE_EVOLUTION_API_KEY=your_evolution_api_key_here
VITE_EVOLUTION_INSTANCE_NAME=your_evolution_instance_name_here

# Metabase
VITE_METABASE_API_URL=your_metabase_url_here

# Custom App
VITE_CUSTOM_APP_URL=your_custom_app_url_here

# Google Search
VITE_GOOGLE_SEARCH_KEY=your_google_search_key_here
VITE_GOOGLE_SEARCH_CX=your_google_search_cx_here

# E2E Test Configuration (Optional - for automated authentication)
# If you don't set these, tests will attempt to use Google OAuth
# To get these values:
# 1. Create a test user account in your Supabase project
# 2. Set the email and password below
TEST_EMAIL=your_test_email_here
TEST_PASSWORD=your_test_password_here

# API Configuration
VITE_API_URL=http://localhost:3000

# n8n Webhook (for WhatsApp message processing)
VITE_N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# PDF Extractor Microservice
VITE_PDF_EXTRACTOR_URL=your_pdf_extractor_url_here

# Google OAuth Configuration
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# SECURITY NOTE (2026-01-08): All hardcoded secrets removed
# OAuth client secret is stored securely in Supabase Edge Function secrets.
# Token refresh is handled server-side via oauth-token-refresh Edge Function.
# Only the Client ID is needed in the frontend for initiating OAuth flow.
# See SECURITY_SETUP.md for instructions on populating these values.
   