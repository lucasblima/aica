{
  "hosting": {
    "target": "production",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
        ]
      },
      {
        "source": "workbox-*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
        ]
      },
      {
        "source": "sw-share-target.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "aica",
          "region": "southamerica-east1"
        }
      }
    ]
  }
}