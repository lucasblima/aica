{
  "hosting": {
    "target": "production",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "aica",
          "region": "southamerica-east1"
        }
      }
    ]
  }
}